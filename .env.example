# Supabase (client-side, exposed to the browser)
# Optional — used to persist a saved copy of each contact message. The form
# still emails you without this; Supabase is only for keeping a record.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Web3Forms — powers the contact form's email delivery to harshraiwork600@gmail.com.
# REQUIRED for the form to actually send. To get your key:
#   1. Go to https://web3forms.com
#   2. Sign up / create an access key using the email harshraiwork600@gmail.com
#   3. Paste the key below.
# This value is safe to expose to the browser: it only permits submissions that
# are emailed to the account owner (you), nothing else.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
